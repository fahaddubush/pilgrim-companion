# Choose: ollama (fully local) or api (OpenAI-compatible endpoint)
LLM_PROVIDER=ollama

# Local Ollama mode
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# API mode (required only when LLM_PROVIDER=api)
API_MODEL=
API_BASE_URL=
API_KEY=

# Shared generation settings
MAX_TOKENS=256
TEMPERATURE=0.2
TOP_P=0.9

# Retrieval: fast defaults for the bundled 185-chunk knowledge base
EMBEDDING_MODEL=intfloat/multilingual-e5-small
RETRIEVAL_CANDIDATES=12
RETRIEVAL_TOP_K=4
MINIMUM_DENSE_SCORE=0.42
SEMANTIC_CACHE_THRESHOLD=0.92
QUERY_CACHE_SIZE=128
RESPONSE_CACHE_SIZE=64

# Optional accuracy mode. This downloads and runs a larger multilingual reranker.
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

HOST=0.0.0.0
PORT=8000
RELOAD=false
